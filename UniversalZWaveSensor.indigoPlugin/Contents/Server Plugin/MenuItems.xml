<?xml version="1.0" encoding="UTF-8"?>
<MenuItems>
    <MenuItem id="simulateReportDialog">
        <Name>Simulate Z-Wave Report...</Name>
        <ConfigUI>
            <Field id="deviceId" type="menu" defaultValue="">
                <Label>Plugin Device</Label>
                <Description>Select which plugin device should receive the simulated report</Description>
                <List class="self" method="get_sim_device_list" dynamicReload="false"/>
            </Field>
            <Field id="hexBytes" type="textfield" defaultValue="">
                <Label>Hex Bytes</Label>
                <Description>Space-separated hex bytes, e.g.:  31 05 01 22 00 D7  (temperature 21.5 degC)</Description>
            </Field>
            <Field id="sendButton" type="button">
                <Label> </Label>
                <Title>Send</Title>
                <CallbackMethod>simulateReport</CallbackMethod>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="generateSupportReportDialog">
        <Name>Generate Indigo Support Report...</Name>
        <ConfigUI>
            <Field id="deviceId" type="menu" defaultValue="">
                <Label>Plugin Device</Label>
                <Description>Select a plugin device — all Z-Wave properties will be written to the Indigo log, ready to paste into the Indigo forum for Matt and Jay</Description>
                <List class="self" method="get_support_device_list" dynamicReload="false"/>
            </Field>
            <Field id="generateButton" type="button">
                <Label> </Label>
                <Title>Generate Report</Title>
                <CallbackMethod>generateSupportReport</CallbackMethod>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="sep1" isSeparator="true"/>
    <MenuItem id="showPluginInfo">
        <Name>Show Plugin Info</Name>
        <CallbackMethod>showPluginInfo</CallbackMethod>
    </MenuItem>
</MenuItems>
